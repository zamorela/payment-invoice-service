# HTTP
PORT=3000

# MongoDB — требуется replica set (нужен для транзакций при зачислении).
# Локально: mongod --replSet rs0  →  один раз mongosh: rs.initiate()
MONGO_URI=mongodb://127.0.0.1:27017/payments?replicaSet=rs0

# Redis
REDIS_URL=redis://127.0.0.1:6379

# Секрет для проверки HMAC-SHA256 подписи webhook (минимум 16 символов)
WEBHOOK_SECRET=super-secret-key-change-me

# Допустимое окно времени для webhook (в секундах) — защита от replay по timestamp
WEBHOOK_TOLERANCE_SECONDS=300
